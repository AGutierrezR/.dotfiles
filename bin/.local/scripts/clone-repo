_clone-repo() {
  local dev_dir="$HOME/Developer"

  local repo_url
  if [[ -n "$1" ]]; then
    repo_url="$1"
  else
    repo_url=$(gum input --placeholder="Git repo URL...") || return 0
    [[ -z "$repo_url" ]] && return 0
  fi

  local repo_url_clean=$(echo "$repo_url" | xargs)

  if [[ -z "$repo_url_clean" ]]; then
    gum style --foreground="red" "Error: Repository URL cannot be empty"
    sleep 2
    return 1
  fi

  local repo_name="${repo_url_clean%/}"
  repo_name="${repo_name##*/}"
  repo_name="${repo_name%.git}"

  if [[ -z $repo_name ]]; then
      gum style --foreground="red" "Error: Could not determine repository name from URL"
    sleep 2
    return 1
  fi

  local repo_path="$dev_dir/$repo_name"

mkdir -p "$dev_dir"

  if [[ -d $repo_path ]]; then
      gum style --foreground="yellow" "Repository already exists at $repo_path"

    if gum confirm "Pull latest changes?"; then
      cd "$repo_path" || return 1
      git pull
      echo "$repo_path"
    fi
  else
    local clone_type=$(gum choose --header="Select clone type:" "Shallow clone (--depth 1)" "Full clone") || return 0

    gum style --foreground="blue" "Cloning $repo_url_clean to $repo_path..."

    if [[ $clone_type == "Shallow clone (--depth 1)" ]]; then
      if ! git clone --depth 1 "$repo_url_clean" "$repo_path"; then
          gum style --foreground="red" "Error: Failed to clone repository"
        sleep 2
        return 1
      fi
    else
      if ! git clone "$repo_url_clean" "$repo_path"; then
          gum style --foreground="red" "Error: Failed to clone repository"
        sleep 2
        return 1
        fi
      fi

    gum style --foreground="green" "Successfully cloned repository!"

    zoxide add "$repo_path"
  fi

  cd "$repo_path"
}

_clone-repo "$@"

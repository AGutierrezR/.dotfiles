#!/bin/bash

# Clone a git repo to ~/Developer/ and create/switch to tmux session
dev_dir="$HOME/Developer"

# Get git URL from user input
repo_url=$(gum input --placeholder="Git repo URL...") || exit 0

# Exit if no input provided (user pressed escape or empty input)
if [[ -z "$repo_url" ]]; then
  exit 0
fi

# Trim whitespace
repo_url=$(echo "$repo_url" | xargs)

# Verify repo_url is not empty after trimming
if [[ -z "$repo_url" ]]; then
  gum style --foreground="red" "Error: Repository URL cannot be empty"
  sleep 2
  exit 1
fi

# Extract repo name from URL/path
repo_name="${repo_url%/}"
repo_name="${repo_name##*/}"
repo_name="${repo_name%.git}"

if [[ -z $repo_name ]]; then
    gum style --foreground="red" "Error: Could not determine repository name from URL"
  sleep 2
  exit 1
fi

repo_path="$dev_dir/$repo_name"

# Create dev directory if it doesn't exist
mkdir -p "$dev_dir"

# Check if repo already exists
if [[ -d $repo_path ]]; then
    gum style --foreground="yellow" "Repository already exists at $repo_path"

  # Ask if user wants to pull latest changes
    if gum confirm "Pull latest changes?"; then
    cd "$repo_path" || exit 1
    git pull
  fi
else
  # Ask if user wants shallow or full clone
  clone_type=$(gum choose --header="Select clone type:" "Shallow clone (--depth 1)" "Full clone") || exit 0

  # Clone the repository
    gum style --foreground="blue" "Cloning $repo_url to $repo_path..."

  if [[ $clone_type == "Shallow clone (--depth 1)" ]]; then
    if ! git clone --depth 1 "$repo_url" "$repo_path"; then
        gum style --foreground="red" "Error: Failed to clone repository"
      sleep 2
      exit 1
    fi
  else
    if ! git clone "$repo_url" "$repo_path"; then
        gum style --foreground="red" "Error: Failed to clone repository"
        sleep 2
        exit 1
      fi
    fi

  gum style --foreground="green" "Successfully cloned repository!"

  # Add directory to zoxide
  zoxide add "$repo_path"
fi

# Check if tmux session with repo name already exists
if tmux has-session -t "$repo_name" 2>/dev/null; then
  # Session exists, switch to it
  tmux switch-client -t "$repo_name"
else
  # Create new session in the repo directory and switch to it
  tmux new-session -d -s "$repo_name" -c "$repo_path"
  tmux switch-client -t "$repo_name"
fi

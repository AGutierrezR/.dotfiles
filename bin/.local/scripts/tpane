#!/usr/bin/env bash

# Toggle a special tmux pane: if it exists, kill it; otherwise create a new split pane
# Get the stored pane ID from the custom tmux window option @myspecialpane
P=$(tmux show -wqv @myspecialpane)
# Check if the pane ID exists and is still a valid/active pane
if [ -n "$P" ] && tmux lsp -F'#{pane_id}' | grep -q ^$P; then
     # Pane exists, so kill it and unset the stored pane ID
     tmux killp -t$P
     tmux set -wu @myspecialpane
else
     # Pane doesn't exist, so create a new horizontal split (15% height) and store its ID
     P=$(tmux splitw -p 15 -PF'#{pane_id}')
     tmux set -w @myspecialpane "$P"
fi
